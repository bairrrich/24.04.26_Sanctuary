generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== Gamification System ====================

model Character {
  id              String   @id @default(cuid())
  name            String
  avatar          String?
  level           Int      @default(1)
  totalXP         Int      @default(0)
  currentClassId  String   @default("novice")
  isSetupComplete Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attributes     CharacterAttribute[]
  xpEvents       XPEvent[]
  achievements   UserAchievement[]
  questProgress  UserQuest[]
  setupData      CharacterSetupData?
}

model CharacterAttribute {
  id          String   @id @default(cuid())
  characterId String
  attribute   String   // strength, agility, intelligence, endurance, charisma
  xp          Int      @default(0)
  level       Int      @default(1)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, attribute])
}

model XPEvent {
  id          String   @id @default(cuid())
  characterId String
  module      String   // source module: habits, nutrition, training, etc.
  action      String   // specific action: habit_complete, workout_done, etc.
  attribute   String   // which RPG attribute gets XP
  amount      Int      // XP amount
  metadata    String?  // JSON string for additional data
  createdAt   DateTime @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model UserAchievement {
  id            String   @id @default(cuid())
  characterId   String
  achievementId String   // reference to achievement definition
  unlockedAt    DateTime @default(now())
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, achievementId])
}

model UserQuest {
  id          String    @id @default(cuid())
  characterId String
  questId     String    // reference to quest definition
  status      String    @default("active") // active, completed, failed, expired
  progress    Int       @default(0)
  target      Int
  completedAt DateTime?
  expiresAt   DateTime?
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, questId])
}

model CharacterSetupData {
  id              String   @id @default(cuid())
  characterId     String   @unique
  // Physical params (for training module)
  height          Float?
  weight          Float?
  age             Int?
  gender          String?
  // Finance (initial accounts)
  initialAccounts String?  // JSON: [{name, balance, currency}]
  // Nutrition goals
  dailyCalories   Int?
  dailyProtein    Int?
  dailyFat        Int?
  dailyCarbs      Int?
  dailyWater      Int?     // in ml
  // Training level
  fitnessLevel    String?  // beginner, intermediate, advanced
  // Habits
  targetSleepHours Float?
  targetWakeTime   String?
  // Preferences
  focusAreas      String?  // JSON: ["strength", "endurance"]
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

// ==================== Habits Module ====================

model Habit {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String   @default("🎯")
  color       String   @default("#06b6d4")
  type        String   @default("positive") // positive, negative
  frequency   String   @default("daily")    // daily, weekly, custom
  targetCount Int      @default(1)           // how many times per period
  sortOrder   Int      @default(0)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      String   // YYYY-MM-DD format for easy querying
  count     Int      @default(1)
  note      String?
  createdAt DateTime @default(now())

  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

// ==================== Nutrition Module ====================

model MealEntry {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  mealType    String   // breakfast, lunch, dinner, snack
  name        String
  calories    Int      @default(0)
  protein     Float    @default(0)
  fat         Float    @default(0)
  carbs       Float    @default(0)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WaterLog {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD
  amount    Int      @default(250) // ml
  createdAt DateTime @default(now())

  @@unique([id])
}

// ==================== Training Module ====================

model Workout {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  name        String
  duration    Int      @default(0)  // minutes
  type        String   @default("strength") // strength, cardio, flexibility, other
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exercises   Exercise[]
}

model Exercise {
  id         String   @id @default(cuid())
  workoutId  String
  name       String
  sets       Int      @default(0)
  reps       Int      @default(0)
  weight     Float    @default(0) // kg
  duration   Int      @default(0) // seconds (for timed exercises)
  isPR       Boolean  @default(false) // personal record
  note       String?
  sortOrder  Int      @default(0)

  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

// ==================== Finance Module ====================

model Account {
  id        String   @id @default(cuid())
  name      String
  balance   Float    @default(0)
  currency  String   @default("RUB")
  icon      String   @default("💰")
  color     String   @default("#10b981")
  sortOrder Int      @default(0)
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  accountId   String
  amount      Float    // positive = income, negative = expense
  category    String   @default("other") // food, transport, entertainment, shopping, health, education, salary, other
  description String?
  date        String   // YYYY-MM-DD
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Budget {
  id          String   @id @default(cuid())
  category    String   @unique
  amount      Float    // monthly budget amount
  period      String   @default("monthly") // weekly, monthly, yearly
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Diary Module ====================

model DiaryEntry {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD
  title     String?
  content   String
  mood      String?  // great, good, neutral, bad, terrible
  tags      String?  // JSON: ["tag1", "tag2"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== Health Module ====================

model BodyMeasurement {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  weight      Float?   // kg
  height      Float?   // cm
  waist       Float?   // cm
  chest       Float?   // cm
  hips        Float?   // cm
  bicep       Float?   // cm
  thigh       Float?   // cm
  neck        Float?   // cm
  bodyFat     Float?   // percentage
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WellbeingLog {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  mood        String?  // great, good, neutral, bad, terrible
  energy      Int?     // 1-10 scale
  sleepHours  Float?   // hours
  sleepQuality Int?    // 1-5 scale
  stress      Int?     // 1-10 scale
  symptoms    String?  // JSON: ["headache", "fatigue", ...]
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HealthGoal {
  id          String   @id @default(cuid())
  type        String   // weight, body_fat, waist, sleep, energy, etc.
  targetValue Float
  currentValue Float?
  deadline    String?  // YYYY-MM-DD
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Calendar Module ====================

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String   // YYYY-MM-DD
  timeStart   String?  // HH:mm
  timeEnd     String?  // HH:mm
  type        String   @default("personal") // personal, work, health, social, finance, training, other
  location    String?
  isRecurring Boolean  @default(false)
  recurRule   String?  // JSON: { freq: "weekly", days: ["mon", "wed"] }
  isCompleted Boolean  @default(false)
  color       String?  // hex color for display
  reminderAt  DateTime? // when to remind
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Looksmaxxing Module ====================

model Routine {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("skincare") // skincare, grooming, style, fitness, nutrition, posture, other
  icon        String   @default("✨")
  frequency   String   @default("daily") // daily, weekly, custom
  steps       String?  // JSON: ["Step 1", "Step 2", ...]
  sortOrder   Int      @default(0)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        RoutineLog[]
}

model RoutineLog {
  id          String   @id @default(cuid())
  routineId   String
  date        String   // YYYY-MM-DD
  completedSteps Int?  // how many steps completed
  rating      Int?     // 1-5 self-rating
  note        String?
  photoUrl    String?  // progress photo reference
  createdAt   DateTime @default(now())

  routine     Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@unique([routineId, date])
}

model ProgressPhoto {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  category    String   @default("face") // face, body, style, other
  note        String?
  photoData   String?  // base64 or URL placeholder
  rating      Int?     // 1-10 self-rating
  createdAt   DateTime @default(now())
}

// ==================== Shifts Module ====================

model Shift {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  timeStart   String   // HH:mm
  timeEnd     String   // HH:mm
  type        String   @default("regular") // regular, overtime, holiday, sick, vacation
  role        String?  // job title/role
  location    String?
  note        String?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Feed Module ====================

model FeedPost {
  id        String   @id @default(cuid())
  content   String
  mood      String?  // great, good, neutral, bad
  tags      String?  // JSON
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== Collections Module ====================

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String   @default("📁")
  color       String   @default("#6366f1")
  type        String   @default("general") // books, movies, games, music, recipes, general
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       CollectionItem[]
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  name         String
  description  String?
  rating       Int?     // 1-5
  status       String   @default("planned") // planned, in_progress, completed
  review       String?
  tags         String?  // JSON
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

// ==================== Reminders Module ====================

model Reminder {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String   // YYYY-MM-DD
  time        String?  // HH:mm
  isCompleted Boolean  @default(false)
  isRecurring Boolean  @default(false)
  recurRule   String?  // JSON
  priority    String   @default("normal") // low, normal, high, urgent
  category    String   @default("general") // general, health, finance, work, personal
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Genealogy Module ====================

model FamilyMember {
  id        String   @id @default(cuid())
  name      String
  relation  String   // mother, father, sister, brother, spouse, child, grandparent, other
  birthDate String?
  photoUrl  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FamilyEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String
  type        String   @default("other") // birthday, anniversary, holiday, reunion, other
  memberId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Keep existing models for future use
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
